# ============================================================
# UPLOAD PROVIDER CONFIGURATION
# ============================================================
# Choose one provider: local | cloudinary | r2 | gcs
UPLOAD_PROVIDER=local

# ------------------------------------------------------------
# LOCAL PROVIDER
# Absolute path to the folder outside the project where uploaded files will be stored.
# Files are served via: GET /api/cms/upload/file/[...path]
# ------------------------------------------------------------
UPLOAD_LOCAL_PATH=/absolute/path/to/uploads

# ------------------------------------------------------------
# CLOUDINARY PROVIDER
# Sign up and get your credentials at https://cloudinary.com
# ------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# Optional: default subfolder in Cloudinary. Default: uploads
CLOUDINARY_FOLDER=uploads

# ------------------------------------------------------------
# CLOUDFLARE R2 PROVIDER
# Create a bucket in the Cloudflare Dashboard > R2
# R2_PUBLIC_URL: custom domain or public bucket URL
#   Examples: https://cdn.example.com or https://pub-xxxx.r2.dev
# ------------------------------------------------------------
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=your_bucket_name
R2_PUBLIC_URL=https://cdn.example.com

# ------------------------------------------------------------
# GOOGLE CLOUD STORAGE (GCS) PROVIDER
# Create a bucket in Google Cloud Console > Cloud Storage
# Docs: https://cloud.google.com/storage/docs
#
# Authentication — choose one:
#   1. GCS_KEY_JSON  — paste service account key JSON as a single string (recommended for hosting/VPS)
#   2. GOOGLE_APPLICATION_CREDENTIALS — path to service account JSON file (for local development or VM)
#
# GCS_PUBLIC_URL: optional. Default: https://storage.googleapis.com/{GCS_BUCKET}
#   Use a custom domain if the bucket is configured with Cloud CDN or a CNAME.
#   Ensure the bucket is set to "Public Access" or use Signed URLs for private files.
# GCS_FOLDER: optional. Default subfolder inside the bucket.
# ------------------------------------------------------------
GCS_PROJECT_ID=your_gcp_project_id
GCS_BUCKET=your_bucket_name
GCS_PUBLIC_URL=https://storage.googleapis.com/your_bucket_name
GCS_FOLDER=uploads
# Service account key JSON (single line, escape if necessary)
GCS_KEY_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...@....iam.gserviceaccount.com",...}
# Or: path to JSON file (if not using GCS_KEY_JSON)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ============================================================
# DATABASE CONFIGURATION
# ============================================================
# Use MongoDB Atlas or any other MongoDB service.
# Make sure to allow connections from your server's IP address.
# Example URI: mongodb+srv://username:password@host:port
# The database name is used to create or connect to the database in MongoDB.
MONGODB_URI="mongodb+srv://username:password@host:port"
MONGODB_DB_NAME="your_database_name"

# ============================================================
# CMS CONFIGURATION
# ============================================================
# CMS_AUTH_SECRET: random string used to sign session tokens. Use a secure random string generator.
# CMS_SETUP_SECRET: random string used to protect the initial admin setup endpoint.
#   After setup is complete, you can delete or rotate this value for extra security.
# Example generator: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Keep these values secret and never share them publicly.
CMS_AUTH_SECRET="your-secure-random-auth-secret"
CMS_SETUP_SECRET="your-secure-random-setup-secret"

# ============================================================
# ANALYTICS CONFIGURATION
# ============================================================
# If you are using Umami for analytics, fill in the variables below with values from your Umami dashboard.
# NEXT_PUBLIC_UMAMI_WEBSITE_ID: the website ID created in Umami
# NEXT_PUBLIC_UMAMI_ANALYTICS_URL: your Umami analytics endpoint URL, e.g. https://your-umami-domain/analytics/website-id
NEXT_PUBLIC_UMAMI_WEBSITE_ID=""
NEXT_PUBLIC_UMAMI_ANALYTICS_URL=""